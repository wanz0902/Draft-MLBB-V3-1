{
  "name": "mlbb-draft-simulator",
  "version": "1.0.0",
  "description": "Mobile Legends professional draft pick simulator and Liquipedia stats dashboard.",
  "main": "dist/server.cjs",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "api": "cd /d \"D:\\MLBB Web\\api-mobilelegends-main\" && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 4000",
    "clear:ports": "kill-port 3001 4000 24680",
    "preall": "npm run clear:ports",
    "all": "concurrently -k -n node,api -c cyan,yellow \"npm run dev\" \"npm run api\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "test:db": "tsx scripts/test-neon-connection.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "validate:assets": "tsx scripts/validate-assets.ts",
    "sync:global-rank": "tsx scripts/sync-global-rank.ts",
    "sync:items": "tsx scripts/sync-items.ts",
    "sync:emblems": "tsx scripts/sync-emblems.ts",
    "sync:battle-spells": "tsx scripts/sync-battle-spells.ts",
    "sync:liquipedia": "tsx scripts/sync-liquipedia.ts",
    "sync:liquipedia:details": "tsx scripts/sync-liquipedia-detail-data.ts",
    "sync:liquipedia:live": "tsx scripts/sync-liquipedia-live-hub.ts",
    "sync:liquipedia:live:ag": "tsx scripts/sync-liquipedia-live-hub.ts --source=asian-games-2026-qualifiers --api-only",
    "sync:pro-player-assets": "tsx scripts/sync-pro-player-assets.ts",
    "scrape:player-detail": "tsx scripts/scrape-player-detail.ts",
    "sync:player-photos": "tsx scripts/sync-player-photos.ts",
    "sync:player-photos:id": "tsx scripts/sync-player-photos.ts --manifest=data/player-photo-sources-indonesia.json",
    "report:player-photos": "tsx scripts/report-player-photo-coverage.ts",
    "report:player-photos:id": "tsx scripts/report-indonesia-player-photos.ts",
    "sync:mlbb-data": "npm run sync:items && npm run sync:emblems && npm run sync:battle-spells"
  },
  "keywords": [
    "mlbb",
    "draft",
    "simulator",
    "liquipedia",
    "stats"
  ],
  "author": "AI Studio Build",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "connect-pg-simple": "^10.0.0",
    "date-fns": "^4.3.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "firebase": "^12.13.0",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.41.0",
    "p-queue": "^9.3.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/node": "^22.14.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
