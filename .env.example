# Hosted MLBB API provider
CUSTOM_MLBB_API_URL=https://openmlbb.fastapicloud.dev

# Standard provider fallback (network errors only):
CUSTOM_MLBB_API_FALLBACK_URL=https://mlbb.rone.dev

# APIGames MLBB nickname checker — backend only
APIGAMES_BASE_URL=https://v1.apigames.id
APIGAMES_MERCHANT_ID=
APIGAMES_SECRET_KEY=
APIGAMES_GAME_CODE=mobilelegend
APIGAMES_TIMEOUT_MS=15000

# APIGames public docs only document one `user_id` parameter.
# Keep `uid` unless APIGames officially confirms another MLBB format.
APIGAMES_MLBB_ID_FORMAT=uid

# Cache successful account checks to reduce paid API requests.
MLBB_ACCOUNT_CACHE_TTL_DAYS=30
